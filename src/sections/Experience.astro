---
import SectionHeading from '../components/SectionHeading.astro';

interface ExperienceItem {
  role: string;
  company: string;
  period: string;
  achievements: string[];
}

const experiences: ExperienceItem[] = [
  {
    role: 'Digital Transformation Officer',
    company: 'PT Mas Arya Indonesia',
    period: '2025 — Present',
    achievements: [
      'Developing digital solutions that streamline operational workflows and improve business efficiency across departments.',
      'Building Power BI dashboards for production monitoring, offering trends, and management reporting.',
      'Designing and implementing internal applications to support digital transformation initiatives.',
      'Collaborating with business stakeholders to translate operational challenges into scalable technology solutions.',
    ],
  },
  {
    role: 'Freelance Full Stack Laravel Developer',
    company: 'Self Employed',
    period: '2024 — Present',
    achievements: [
      'Developing custom web applications using Laravel, MySQL, and modern frontend technologies.',
      'Building business systems including Gym Management Systems, Membership Platforms, and Company Profile Websites.',
      'Implementing QR Code based attendance systems, reporting modules, and payment gateway integrations.',
      'Delivering end-to-end solutions from requirement gathering and system design to deployment and maintenance.',
    ],
  },
  {
    role: 'IT Support Supervisor',
    company: 'PT Pos Indonesia',
    period: '2020 — 2024',
    achievements: [
      'Managed IT infrastructure, user support, and operational systems across multiple business functions.',
      'Led troubleshooting and system improvement initiatives to minimize downtime and improve service reliability.',
      'Coordinated technology adoption and supported digitalization efforts within operational teams.',
      'Provided technical guidance and support for software, hardware, and network-related issues.',
    ],
  },
  {
    role: 'Management Trainee',
    company: 'PT Pos Indonesia',
    period: '2018 — 2020',
    achievements: [
      'Participated in management development programs focused on business operations and technology support.',
      'Learned cross-functional business processes including logistics, customer service, and operational management.',
      'Contributed to process improvement initiatives through technology and data-driven approaches.',
      'Built a strong foundation in problem-solving, leadership, and organizational workflows.',
    ],
  },
];
---

<section
  id="experience"
  class="relative overflow-hidden px-6 py-28 md:py-36"
>
  <div class="mx-auto max-w-7xl">
    <SectionHeading
      index="02"
      title="Experience"
    />
    <div class="relative mx-auto max-w-3xl">
      <div
        id="timeline-line"
        class="absolute left-[11px] top-3 h-full w-px origin-top scale-y-0 bg-border md:left-[13px]"
      />
      <div class="space-y-16">
        {experiences.map((exp) => (
          <div class="timeline-item relative grid grid-cols-[28px_1fr] gap-6 md:gap-8">
            <div class="relative flex justify-center">
              <div class="relative z-10 mt-1.5 flex h-5 w-5 items-center justify-center md:h-6 md:w-6">
                <div class="absolute inset-0 rounded-full border-2 border-accent bg-surface" />
                <div class="absolute inset-0.5 rounded-full bg-accent/20" />
                <div class="h-1.5 w-1.5 rounded-full bg-accent md:h-2 md:w-2" />
              </div>
            </div>
            <div>
              <span class="inline-flex items-center gap-2 text-xs font-medium uppercase tracking-[0.15em] text-accent">
                <span class="inline-block h-px w-4 bg-accent/40" />
                {exp.period}
              </span>
              <h3 class="mt-3 text-xl font-bold tracking-tight text-on-surface sm:text-2xl">
                {exp.role}
              </h3>
              <p class="mt-1 text-sm font-medium text-on-surface-secondary">
                {exp.company}
              </p>
              <ul class="mt-4 space-y-3">
                {exp.achievements.map((achievement) => (
                  <li class="flex items-start gap-3 text-sm leading-relaxed text-on-surface-secondary">
                    <span class="mt-2 block h-0.5 w-4 shrink-0 rounded-full bg-accent/40" />
                    {achievement}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('#timeline-line', {
    scaleY: 1,
    duration: 1.5,
    ease: 'power3.inOut',
    scrollTrigger: {
      trigger: '#experience',
      start: 'top 70%',
      end: 'bottom 30%',
      scrub: 1,
    },
  });

  gsap.from('.timeline-item', {
    y: 50,
    opacity: 0,
    duration: 0.8,
    stagger: 0.25,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#experience',
      start: 'top 70%',
      toggleActions: 'play none none reverse',
    },
  });
</script>
