---
import SectionHeading from '../components/SectionHeading.astro';

interface ExperienceItem {
  role: string;
  company: string;
  period: string;
  description: string[];
}

const experiences: ExperienceItem[] = [
  {
    role: 'Senior Laravel Developer',
    company: 'Tech Corp',
    period: '2023 — Present',
    description: [
      'Architected and built scalable microservices using Laravel and MySQL.',
      'Led a team of 4 developers, implementing CI/CD pipelines and code review processes.',
      'Reduced API response times by 40% through query optimization and caching strategies.',
    ],
  },
  {
    role: 'Full Stack Developer',
    company: 'Digital Agency',
    period: '2021 — 2023',
    description: [
      'Developed 10+ client projects using Laravel, Livewire, and TailwindCSS.',
      'Built custom admin panels with real-time data synchronization.',
      'Integrated third-party APIs including payment gateways and SaaS platforms.',
    ],
  },
  {
    role: 'Junior PHP Developer',
    company: 'Startup Inc.',
    period: '2019 — 2021',
    description: [
      'Maintained and improved legacy PHP applications, migrating to Laravel.',
      'Developed RESTful APIs for mobile application backends.',
      'Wrote comprehensive test suites achieving 85% code coverage.',
    ],
  },
];
---

<section
  id="experience"
  class="relative overflow-hidden px-6 py-28 md:py-36 lg:px-10"
>
  <div class="container mx-auto">
    <SectionHeading
      index="04"
      title="Experience"
      subtitle="My professional journey so far."
    />
    <div class="relative mx-auto max-w-3xl">
      <div class="timeline-line absolute left-[11px] top-3 h-full w-px bg-border md:left-[13px]" />
      <div class="space-y-16">
        {experiences.map((exp, i) => (
          <div class="exp-item relative grid grid-cols-[28px_1fr] gap-6 md:gap-8">
            <div class="relative flex justify-center">
              <div class="relative z-10 mt-1.5 flex h-5 w-5 items-center justify-center md:h-6 md:w-6">
                <div class="absolute inset-0 rounded-full border-2 border-accent bg-surface transition-transform duration-500 hover:scale-150" />
                <div class="absolute inset-0.5 rounded-full bg-accent/20" />
                <div class="h-1.5 w-1.5 rounded-full bg-accent md:h-2 md:w-2" />
              </div>
            </div>
            <div>
              <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.15em] text-accent">
                <span class="inline-block h-px w-4 bg-accent/40" />
                {exp.period}
              </span>
              <h3 class="mt-3 text-xl font-bold tracking-tight text-on-surface sm:text-2xl">
                {exp.role}
              </h3>
              <p class="mt-1 text-sm font-medium text-on-surface-muted">
                {exp.company}
              </p>
              <ul class="mt-4 space-y-3">
                {exp.description.map((desc) => (
                  <li class="flex items-start gap-3 text-sm leading-relaxed text-on-surface-muted">
                    <span class="mt-2 block h-0.5 w-4 shrink-0 rounded-full bg-accent/40" />
                    {desc}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.set('.timeline-line', { scaleY: 0 });

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: '#experience',
      start: 'top 70%',
      toggleActions: 'play none none reverse',
    },
  });

  tl.to('.timeline-line', { scaleY: 1, duration: 1.2, ease: 'power3.inOut', transformOrigin: 'top center' })
    .from('.exp-item', { y: 50, opacity: 0, duration: 0.8, stagger: 0.25, ease: 'power3.out' }, '-=0.6');
</script>
