---
import SectionHeading from '../components/SectionHeading.astro';
---

<section
  id="about"
  class="relative overflow-hidden px-6 py-28 md:py-36"
>
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-0 left-1/4 h-px w-1/2 bg-gradient-to-r from-transparent via-border to-transparent" />
  </div>
  <div class="mx-auto max-w-7xl">
    <SectionHeading
      index="01"
      title="About"
    />
    <div class="grid gap-16 lg:grid-cols-5">
      <div class="about-col space-y-6 lg:col-span-3">
        <p class="text-lg leading-relaxed text-on-surface-secondary sm:text-xl">
          I bridge the gap between business strategy and technical execution. As a Digital Transformation Officer and Full Stack Laravel Developer, I help organizations modernize their operations through scalable web applications and data-driven intelligence.
        </p>
        <p class="text-lg leading-relaxed text-on-surface-secondary sm:text-xl">
          Every solution I build is focused on measurable business impact — reducing operational costs, streamlining workflows, and enabling data-informed decisions. From architecting complex Laravel systems to designing Power BI dashboards that surface actionable insights, I deliver technology that drives real results.
        </p>
        <p class="text-lg leading-relaxed text-on-surface-secondary sm:text-xl">
          I don't just write code. I solve business problems with technology.
        </p>
      </div>
      <div class="flex flex-col gap-6 lg:col-span-2 lg:items-end">
        <div class="inline-flex flex-col gap-8 rounded-2xl border border-border p-8 md:p-10">
          {[
            { value: '6+', label: 'Years of Experience' },
            { value: '10+', label: 'Projects Delivered' },
          ].map((stat) => (
            <div class="stat-item">
              <span class="text-4xl font-bold tracking-tight text-accent sm:text-5xl">
                {stat.value}
              </span>
              <p class="mt-1 text-sm text-on-surface-secondary">
                {stat.label}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add('(min-width: 1024px)', () => {
    gsap.from('.about-col p', {
      scrollTrigger: { trigger: '#about', start: 'top 75%' },
      y: 40,
      opacity: 0,
      duration: 0.8,
      stagger: 0.2,
      ease: 'power3.out',
    });
    gsap.from('.stat-item', {
      scrollTrigger: { trigger: '#about', start: 'top 75%' },
      y: 30,
      opacity: 0,
      duration: 0.6,
      stagger: 0.15,
      ease: 'power3.out',
    });
  });
</script>
