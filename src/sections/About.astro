---
import SectionHeading from '../components/SectionHeading.astro';
---

<section
  id="about"
  class="relative overflow-hidden px-6 py-28 md:py-36 lg:px-10"
>
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-0 left-1/4 h-px w-1/2 bg-gradient-to-r from-transparent via-border to-transparent" />
  </div>
  <div class="container mx-auto">
    <SectionHeading
      index="01"
      title="About"
      subtitle="A bit about me and what I do."
    />
    <div class="grid gap-16 lg:grid-cols-5">
      <div class="about-col space-y-6 lg:col-span-3">
        <p class="text-lg leading-relaxed text-on-surface-muted sm:text-xl">
          I'm a Full Stack Laravel Developer with a passion for building
          robust, scalable web applications. I specialize in crafting
          end-to-end solutions from database design to polished front-end
          interfaces.
        </p>
        <p class="text-lg leading-relaxed text-on-surface-muted sm:text-xl">
          With expertise spanning the entire Laravel ecosystem &mdash; including
          Livewire, Eloquent, Queues, and Testing &mdash; I deliver applications
          that are both developer-friendly and business-ready.
        </p>
        <p class="text-lg leading-relaxed text-on-surface-muted sm:text-xl">
          I believe in clean architecture, RESTful design patterns, and
          writing code that stands the test of time. Every project I ship
          is built with maintainability and performance in mind.
        </p>
      </div>
      <div class="about-stats flex flex-col gap-6 lg:col-span-2 lg:items-end">
        <div class="inline-flex flex-col gap-8 rounded-2xl border border-border p-8 md:p-10">
          {[
            { value: '6+', label: 'Years Building' },
            { value: '20+', label: 'Projects Shipped' },
            { value: '100%', label: 'Commitment to Quality' },
          ].map((stat) => (
            <div class="stat-item">
              <span class="text-4xl font-bold tracking-tight text-accent sm:text-5xl">
                {stat.value}
              </span>
              <p class="mt-1 text-sm text-on-surface-muted">
                {stat.label}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add('(min-width: 1024px)', () => {
    gsap.from('.about-col p', {
      scrollTrigger: { trigger: '#about', start: 'top 75%' },
      y: 40,
      opacity: 0,
      duration: 0.8,
      stagger: 0.2,
      ease: 'power3.out',
    });
    gsap.from('.stat-item', {
      scrollTrigger: { trigger: '#about', start: 'top 75%' },
      y: 30,
      opacity: 0,
      duration: 0.6,
      stagger: 0.15,
      ease: 'power3.out',
    });
  });
</script>
