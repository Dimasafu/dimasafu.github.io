---

---

<section
  id="hero"
  class="relative flex min-h-screen flex-col justify-center overflow-hidden px-6"
>
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-1/4 right-0 h-[600px] w-[600px] rounded-full bg-accent/5 blur-3xl" />
    <div class="absolute bottom-1/4 left-0 h-[400px] w-[400px] rounded-full bg-accent/3 blur-3xl" />
  </div>
  <div class="mx-auto w-full max-w-7xl">
    <div class="max-w-4xl">
      <div class="hero-label mb-6 flex items-center gap-3">
        <span class="inline-flex h-px w-8 bg-accent/60" />
        <span class="text-xs font-medium uppercase tracking-[0.2em] text-accent">
          Digital Transformation Officer
        </span>
      </div>

      <h1 class="hero-name text-[clamp(3rem,10vw,7rem)] font-extrabold leading-[0.85] tracking-[-0.03em] text-on-surface">
        Dimas Aulia
        <br />
        Fadhil
      </h1>

      <div class="hero-role mt-6 max-w-2xl">
        <p class="text-lg leading-relaxed text-on-surface-secondary sm:text-xl md:text-2xl">
          Full Stack Laravel Developer &amp; Digital Transformation Officer
        </p>
      </div>

      <div class="hero-desc mt-4 max-w-xl">
        <p class="text-base leading-relaxed text-on-surface-tertiary">
          I build scalable web applications and data-driven solutions that help businesses modernize, optimize, and grow.
        </p>
      </div>

      <div class="hero-ctas mt-10 flex flex-wrap gap-4">
        <a
          href="#projects"
          data-magnetic
          class="group inline-flex items-center gap-2 rounded-xl bg-on-surface px-7 py-3.5 text-sm font-medium text-surface transition-all duration-300 hover:opacity-90"
        >
          <span class="magnetic-inner inline-flex items-center gap-2">
            View Projects
            <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </span>
        </a>
        <a
          href="#contact"
          data-magnetic
          class="group inline-flex items-center gap-2 rounded-xl border border-border px-7 py-3.5 text-sm font-medium text-on-surface transition-all duration-300 hover:bg-surface-secondary"
        >
          <span class="magnetic-inner">Get in Touch</span>
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <div class="flex flex-col items-center gap-2">
      <span class="text-[10px] font-medium uppercase tracking-[0.2em] text-on-surface-tertiary">
        Scroll
      </span>
      <svg class="h-4 w-4 animate-bounce text-on-surface-tertiary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M6 9l6 6 6-6" />
      </svg>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

  tl.from('.hero-label', { y: 30, opacity: 0, duration: 0.8 })
    .from('.hero-name', { y: 80, opacity: 0, duration: 1 }, '-=0.3')
    .from('.hero-role', { y: 40, opacity: 0, duration: 0.8 }, '-=0.4')
    .from('.hero-desc', { y: 30, opacity: 0, duration: 0.6 }, '-=0.3')
    .from('.hero-ctas > a', { y: 20, opacity: 0, duration: 0.5, stagger: 0.15 }, '-=0.2');
</script>
