---
import SectionHeading from '../components/SectionHeading.astro';

const techs = [
  { name: 'Laravel', category: 'Framework' },
  { name: 'PHP', category: 'Language' },
  { name: 'MySQL', category: 'Database' },
  { name: 'TailwindCSS', category: 'Frontend' },
  { name: 'Livewire', category: 'Frontend' },
  { name: 'AlpineJS', category: 'Frontend' },
  { name: 'Git', category: 'Tooling' },
  { name: 'Linux', category: 'Infra' },
  { name: 'Docker', category: 'Infra' },
];
---

<section
  id="stack"
  class="relative overflow-hidden px-6 py-28 md:py-36 lg:px-10"
>
  <div class="container mx-auto">
    <SectionHeading
      index="03"
      title="Tech Stack"
      subtitle="Tools and technologies I work with daily."
    />
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
      {techs.map((tech) => (
        <div
          class="tech-item group relative overflow-hidden rounded-xl border border-border p-5 text-center transition-all duration-500 hover:border-accent/20 hover:shadow-lg hover:shadow-accent/5"
        >
          <div class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-accent/5 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
          <span class="text-sm font-semibold text-on-surface transition-colors duration-300 group-hover:text-accent">
            {tech.name}
          </span>
          <p class="mt-1 text-[10px] font-medium uppercase tracking-wider text-on-surface-subtle">
            {tech.category}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.tech-item', {
    scrollTrigger: { trigger: '#stack', start: 'top 80%' },
    y: 30,
    opacity: 0,
    duration: 0.5,
    stagger: 0.04,
    ease: 'power2.out',
  });
</script>
