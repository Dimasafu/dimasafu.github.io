---
import SectionHeading from '../components/SectionHeading.astro';

interface TechGroup {
  category: string;
  items: string[];
}

const techGroups: TechGroup[] = [
  {
    category: 'Backend',
    items: ['Laravel', 'PHP', 'Node.js'],
  },
  {
    category: 'Frontend',
    items: ['TailwindCSS', 'JavaScript', 'HTML5'],
  },
  {
    category: 'Database',
    items: ['MySQL', 'Microsoft', 'Database Design'],
  },
  {
    category: 'BI & Analytics',
    items: ['Power BI', 'DAX', 'Power Apps', 'Data Visualization'],
  },
  {
    category: 'DevOps & Tools',
    items: ['Git', 'Linux', 'CI/CD', 'Nginx'],
  },
];
---

<section
  id="tech"
  class="relative overflow-hidden px-6 py-28 md:py-36"
>
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-0 left-1/4 h-px w-1/2 bg-gradient-to-r from-transparent via-border to-transparent" />
  </div>
  <div class="mx-auto max-w-7xl">
    <SectionHeading
      index="04"
      title="Tech Stack"
    />
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
      {techGroups.map((group) => (
        <div class="tech-group">
          <h3 class="text-xs font-semibold uppercase tracking-[0.15em] text-accent">
            {group.category}
          </h3>
          <div class="mt-4 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="tech-item rounded-lg border border-border bg-surface-secondary/50 px-3.5 py-2 text-sm font-medium text-on-surface-secondary transition-colors duration-300 hover:border-accent/20 hover:text-on-surface">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.tech-item', {
    scrollTrigger: { trigger: '#tech', start: 'top 80%' },
    y: 20,
    opacity: 0,
    duration: 0.4,
    stagger: 0.03,
    ease: 'power2.out',
  });
</script>
