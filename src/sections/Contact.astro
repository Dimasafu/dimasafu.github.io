---

---

<section
  id="contact"
  class="relative overflow-hidden px-6 py-28 md:py-36"
>
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-1/2 left-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent/3 blur-3xl" />
  </div>
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-2xl text-center">
      <span class="mb-4 block text-xs font-medium uppercase tracking-[0.2em] text-accent">
        Get in Touch
      </span>
      <h2 class="text-4xl font-bold leading-[1.1] tracking-tight text-on-surface sm:text-5xl lg:text-6xl">
        Let's build something
        <br />
        great together
      </h2>
      <p class="contact-content mx-auto mt-6 max-w-md text-base leading-relaxed text-on-surface-secondary">
        Have a project in mind or want to discuss how I can help your business? Let's talk.
      </p>
      <div class="contact-content mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="mailto:dimasauliafadhil@gmail.com"
          data-magnetic
          class="group inline-flex items-center gap-3 rounded-xl bg-on-surface px-8 py-4 text-sm font-medium text-surface transition-all duration-300 hover:opacity-90"
        >
          <span class="magnetic-inner flex items-center gap-2">
            dimasauliafadhil@gmail.com
            <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      </div>
      <div class="contact-content mt-12 flex justify-center gap-8">
        <a
          href="https://github.com/dimasafu"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-2 text-sm font-medium text-on-surface-secondary transition-colors duration-300 hover:text-on-surface"
        >
          <svg class="h-5 w-5 transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/dimasauliafadhil"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-2 text-sm font-medium text-on-surface-secondary transition-colors duration-300 hover:text-on-surface"
        >
          <svg class="h-5 w-5 transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.contact-content', {
    scrollTrigger: { trigger: '#contact', start: 'top 75%' },
    y: 40,
    opacity: 0,
    duration: 0.8,
    stagger: 0.2,
    ease: 'power3.out',
  });
</script>
