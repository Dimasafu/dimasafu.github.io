---
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectModal from '../components/ProjectModal.astro';
import { projects } from '../data/projects';
---

<section
  id="projects"
  class="relative overflow-hidden px-6 py-28 md:py-36"
>
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-0 left-1/4 h-px w-1/2 bg-gradient-to-r from-transparent via-border to-transparent" />
  </div>
  <div class="mx-auto max-w-7xl">
    <SectionHeading
      index="03"
      title="Featured Projects"
    />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-2 xl:gap-8">
      {projects.map((project, i) => (
        <ProjectCard project={project} index={i} />
      ))}
    </div>
  </div>
</section>

<ProjectModal projects={projects} />

<div id="projects-data" data-projects={JSON.stringify(projects)} hidden></div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('.project-card').forEach((card) => {
    card.addEventListener('click', () => {
      const idx = parseInt(card.dataset.projectIndex);
      if (typeof window.openProjectModal === 'function') {
        window.openProjectModal(idx);
      }
    });
  });

  gsap.utils.toArray('.project-card').forEach((card, i) => {
    gsap.from(card, {
      y: 60,
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: card,
        start: 'top 85%',
        toggleActions: 'play none none reverse',
      },
      delay: i * 0.1,
    });
  });
</script>
