---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
---

<article
  class="project-card group relative cursor-pointer rounded-2xl border border-border bg-surface transition-all duration-500 hover:-translate-y-1 hover:border-accent/20 hover:shadow-xl hover:shadow-accent/5"
  data-project-index={index}
>
  <div class="relative aspect-[16/10] overflow-hidden">
    <img
      src={project.screenshots[0]}
      alt={project.title}
      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/10 to-transparent" />
    <div class="absolute bottom-4 left-4 flex h-10 w-10 items-center justify-center rounded-xl bg-surface/60 backdrop-blur-sm">
      <span class="text-sm font-bold text-accent">{String(index + 1).padStart(2, '0')}</span>
    </div>
    <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-white/5" />
  </div>

  <div class="p-6">
    <h3 class="text-lg font-semibold tracking-tight text-on-surface">
      {project.title}
    </h3>
    <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-on-surface-secondary">
      {project.description}
    </p>
    <div class="mt-4 flex flex-wrap gap-2">
      {project.technologies.slice(0, 4).map((tech) => (
        <span class="rounded-full border border-border bg-surface-secondary/50 px-2.5 py-1 text-xs font-medium text-on-surface-secondary">
          {tech}
        </span>
      ))}
    </div>
    <div class="mt-5 flex translate-y-1 items-center gap-1.5 text-sm font-medium text-accent opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
      View Case Study
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</article>
