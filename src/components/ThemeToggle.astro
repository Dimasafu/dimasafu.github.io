---

<button
  id="theme-toggle"
  class="relative z-40 flex h-10 w-10 cursor-pointer items-center justify-center rounded-xl border border-border bg-transparent transition-all duration-300 hover:bg-surface-secondary"
  aria-label="Toggle theme"
>
  <svg
    class="sun-icon h-5 w-5 text-on-surface transition-all duration-500"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
  >
    <circle cx="12" cy="12" r="5" />
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
  </svg>
  <svg
    class="moon-icon absolute h-5 w-5 text-on-surface transition-all duration-500"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
  >
    <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
  </svg>
</button>

<script>
  const toggle = document.getElementById('theme-toggle');
  const sun = toggle.querySelector('.sun-icon');
  const moon = toggle.querySelector('.moon-icon');

  function updateIcons(theme) {
    if (theme === 'dark') {
      sun.style.opacity = '0';
      sun.style.transform = 'rotate(90deg) scale(0.5)';
      moon.style.opacity = '1';
      moon.style.transform = 'rotate(0deg) scale(1)';
    } else {
      sun.style.opacity = '1';
      sun.style.transform = 'rotate(0deg) scale(1)';
      moon.style.opacity = '0';
      moon.style.transform = 'rotate(90deg) scale(0.5)';
    }
  }

  sun.style.opacity = '1';
  moon.style.opacity = '0';
  moon.style.transform = 'rotate(90deg) scale(0.5)';
  Object.assign(sun.style, { transition: 'all 0.5s cubic-bezier(0.16,1,0.3,1)' });
  Object.assign(moon.style, { transition: 'all 0.5s cubic-bezier(0.16,1,0.3,1)' });

  updateIcons(window.__theme);

  toggle.addEventListener('click', () => {
    const newTheme = window.__theme === 'dark' ? 'light' : 'dark';
    window.__setPreferredTheme(newTheme);
    updateIcons(newTheme);
  });
</script>
