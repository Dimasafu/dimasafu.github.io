---

<footer class="border-t border-border">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
      <div class="max-w-xs space-y-3">
        <a href="#" class="text-sm font-medium tracking-tight text-on-surface">
          Dimas Aulia Fadhil
        </a>
        <p class="text-sm leading-relaxed text-on-surface-secondary">
          Full Stack Laravel Developer & Digital Transformation Officer. Building scalable business solutions that drive impact.
        </p>
      </div>
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-8">
        <div class="flex gap-6">
          {[
            { label: 'GitHub', href: 'https://github.com/afutrade' },
            { label: 'LinkedIn', href: 'https://linkedin.com/in/afutrade' },
            { label: 'Email', href: 'mailto:hello@afutrade.dev' },
          ].map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="text-sm text-on-surface-secondary transition-colors duration-300 hover:text-on-surface"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-border pt-6 sm:flex-row sm:items-center">
      <p class="text-xs text-on-surface-tertiary">
        &copy; {new Date().getFullYear()} Dimas Aulia Fadhil. All rights reserved.
      </p>
      <button id="back-to-top" class="group flex items-center gap-1.5 text-xs font-medium text-on-surface-tertiary transition-colors hover:text-on-surface">
        Back to top
        <svg class="h-3 w-3 transition-transform duration-300 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M18 15l-6-6-6 6" />
        </svg>
      </button>
    </div>
  </div>
</footer>

<script>
  document.getElementById('back-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
